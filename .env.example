# Real Match environment template. Copy to .env.local and fill in.
# Placeholder-only: never commit real values.

# Canonical site URL (used for metadata, sitemap, robots).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Operational status gate: preview | pilot | live
# preview = marketing visible; no applications or payments processed.
# Do not set pilot/live until PRODUCTION_READINESS.md gates are met.
NEXT_PUBLIC_SERVICE_STATUS=preview

# --- Future (server-side only; required before applications open) ---
# Supabase project URL and anon key are safe for the client; the service
# role key is NOT and must only ever live in server environment config.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # server-only; never NEXT_PUBLIC_
# EMAIL_PROVIDER_API_KEY=      # server-only
